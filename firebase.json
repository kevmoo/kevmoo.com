{
  "hosting": {
    "predeploy": "dart pub global run jaspr_cli:jaspr build",
    "site": "work-j832",
    "public": "build/jaspr",
    "cleanUrls": true,
    "ignore": [
      "**/.*",
      "firebase.json"
    ],
    "redirects": [
      {
        "source": "/resume/**",
        "destination": "/",
        "type": 302
      },
      {
        "source": "/resume",
        "destination": "/",
        "type": 302
      },
      {
        "regex": "(?i)/isu[_\\-]?ama",
        "destination": "https://docs.google.com/presentation/d/1rRkOkK1xWnKudFdvXbsZ5VPZtswPLlrNZyWDmkYP6hs/edit?usp=sharing",
        "type": 301
      },
      {
        "source": "/industry-lecture-google",
        "destination": "https://docs.google.com/presentation/d/1E9sqcgeKUuJKmuhYuEzSkH4WpC3273JUBqsjLVVh0OU/edit?usp=sharing",
        "type": 301
      }
    ],
    "headers": [
      {
        "source": "/",
        "headers": [
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "Content-Security-Policy",
            "value": "frame-ancestors 'none'; default-src https:; script-src 'unsafe-eval' https: 'nonce-okoboji'; base-uri 'self'"
          }
        ]
      }
    ]
  }
}
